(echo )>>"%B64%"
(echo )>>"%B64%"

:: decode base64 -> setup.exe
certutil -decode "%B64%" "%EXE%" >nul 2>&1
if not exist "%EXE%" (
  echo Failed to decode setup. & pause & exit /b 1
)

:: run installer
"%EXE%"

:: cleanup temp
del /F /Q "%B64%" >nul 2>&1
del /F /Q "%EXE%" >nul 2>&1
rmdir /Q "%WORK%" >nul 2>&1
endlocal