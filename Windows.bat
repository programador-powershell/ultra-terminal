@echo off
:: Ultra Terminal - Windows self-extracting installer
:: Decodes embedded setup.exe -> runs it -> installs app -> cleanup.

setlocal enabledelayedexpansion
echo.
echo  Ultra Terminal - extracting installer...
echo.

set "WORK=%TEMP%\UltraTerm-%RANDOM%%RANDOM%"
mkdir "%WORK%" 2>nul
set "B64=%WORK%\setup.b64"
set "EXE=%WORK%\setup.exe"

:: write base64 (each chunk on its own line)
(echo )>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
